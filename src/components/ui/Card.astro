---
const { project, image } = Astro.props;

// Verwende cardDescriptionEN mit Fallback-Optionen
const cardDescription =
  project.cardDescriptionEN ||
  project.cardDescriptionEn ||
  project.description?.en ||
  project.description ||
  "No description available";

// Stelle sicher, dass die Kategorie immer gesetzt ist
const category = project.category || "Other";
---

<div
  class:list={["card-wrapper", project.tile && `tile-${project.tile}`]}
  data-category={category}
  data-allowed-sizes={project.grid?.map((s: string) => s.replace(/\s/g, "")).join("|")}
>
  <div class="box card-3d offscreen" data-modal-target={`modal-${project.id}`}>
    <div class="card-content">
      <img
        src={image}
        alt={project.title}
        width={600}
        height={400}
        loading="lazy"
        class="card-image"
      />
      <div class="card-overlay">
        <h3 class="card-title">{project.title}</h3>
        <p class="card-tech">
          {project.technologies?.join(" • ") || "No technologies specified"}
        </p>
        <div class="card-description">
          <p>{cardDescription}</p>
        </div>
        <div class="card-badges">
          {
            project.badges &&
              project.badges.map((badge) => <span class="badge">{badge}</span>)
          }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card-wrapper {
    position: relative;
    z-index: 5;
    perspective: 1000px;
    height: 100%;
    border-radius: 15px;
    box-shadow: var(--card-elev);
    /* Benannter Container für größenabhängiges Overlay (kleine
       Bento-Kacheln) – benannt, damit keine fremde @container-Regel
       versehentlich auf diese Karte matcht. */
    container: project-card / size;
    /* Expliziter Basis-Filter, damit das Spotlight-Dimmen (.has-hover)
       in beide Richtungen weich animiert – nicht nur beim Verdunkeln. */
    filter: brightness(1) saturate(1);
    transition:
      box-shadow 0.4s ease,
      filter 0.3s ease;
  }

  .card-wrapper:hover {
    box-shadow: var(--card-elev-hover);
  }

  .box {
    position: relative;
    overflow: hidden;
    border-radius: 15px;
    cursor: pointer;
    height: 100%;
    transform-style: preserve-3d;
    transform: translateZ(0);
    transition:
      transform 0.5s ease-out,
      box-shadow 0.4s ease;
    background-color: var(--bg-card);
    /* box-shadow: var(--elev-3); */
  }

  /* @keyframes cardGlow {
    0% {
      box-shadow:
      0 0 2px 1px var(--bg-primary),
      0 0 1px 0px var(--accent);
    }
    100% {
      box-shadow:
      0 0 2px 1px var(--bg-primary),
      0 0 5px 0px var(--accent);
    }
  } */

  .card-content {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 15px;
    overflow: hidden;
  }

  /* Akzent-Rahmen über dem Bild – ein inset-Shadow direkt auf .card-content
     würde vom darüber liegenden .card-image verdeckt. */
  .card-content::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 15px;
    box-shadow: inset 0 0 0 1px
      color-mix(in srgb, var(--accent) 25%, transparent);
    pointer-events: none;
    z-index: 2;
    transition: box-shadow 0.4s ease;
  }

  .card-image {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    object-position: top;
    transition:
      transform 0.5s ease-out,
      filter 0.4s ease-out;
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    /* Mehrstufiger Verlauf: unten kräftig, oben weich auslaufend –
       vermeidet die sichtbare Kante eines 2-Stopp-Gradients. */
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85),
      rgba(0, 0, 0, 0.62) 55%,
      rgba(0, 0, 0, 0.3) 82%,
      transparent
    );
    color: white;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
    transform: translateY(100%);
    transition: transform 0.4s ease-out;
    max-height: 90%;
    /* x fest zu: lange Wörter sollen umbrechen, nie horizontal scrollen */
    overflow: hidden auto;
  }

  .card-title {
    font-size: 1.5rem;
    /* Skaliert mit der Kachelbreite – 1,5rem nur wenn Platz da ist */
    font-size: clamp(1rem, 7.5cqi, 1.5rem);
    font-weight: bold;
    margin-bottom: 0.5rem;
    overflow-wrap: break-word;
  }

  .card-tech {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--accent) 65%, white);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description {
    margin: 0.75rem 0;
    font-size: 0.875rem;
    opacity: 0.9;
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }

  .card-description p {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    transition: opacity 0.3s ease-out;
    opacity: 0;
  }

  .badge {
    padding: 0.25rem 0.75rem;
    background-color: var(--accent);
    color: white;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: bold;
  }

  /* Hover Effekte (Elevation liegt auf .card-wrapper) */
  .box:hover .card-content::after {
    box-shadow: inset 0 0 0 1px
      color-mix(in srgb, var(--accent) 60%, transparent);
  }

  .box:hover .card-image {
    transform: scale(1.05);
    filter: blur(5px) brightness(0.55) saturate(1.1);
  }

  .box:hover .card-overlay {
    transform: translateY(0%);
  }

  .box:hover .card-description {
    max-height: 200px;
  }

  .box:hover .card-badges {
    opacity: 1;
  }

  /* Elegante schmale Scrollbar für card-overlay */
  .card-overlay {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 99, 71, 0.5) transparent;
  }

  .card-overlay::-webkit-scrollbar {
    width: 3px;
  }

  .card-overlay::-webkit-scrollbar-track {
    background: transparent;
  }

  .card-overlay::-webkit-scrollbar-thumb {
    background: rgba(255, 99, 71, 0.5);
    border-radius: 999px;
  }

  .card-overlay::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 99, 71, 0.8);
  }

  /* Touch-Geräte: Overlay als Frosted-Glass-Panel, immer sichtbar.
     backdrop-filter macht den Text unabhängig vom Bildmotiv lesbar. */
  @media (hover: none) {
    .card-overlay {
      transform: none;
      max-height: 75%;
      padding: 0.9rem 1rem 1rem;
      background: linear-gradient(
        to top,
        rgba(8, 8, 10, 0.78),
        rgba(8, 8, 10, 0.55)
      );
      backdrop-filter: blur(14px) saturate(1.35);
      -webkit-backdrop-filter: blur(14px) saturate(1.35);
      border-top: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    }

    /* Browser ohne backdrop-filter: kräftigere Abdunklung als Ersatz */
    @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
      .card-overlay {
        background: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.92),
          rgba(0, 0, 0, 0.78)
        );
      }
    }

    .card-title {
      font-size: 1.05rem;
      margin-bottom: 0.15rem;
    }

    .card-tech {
      font-size: 0.7rem;
      margin-bottom: 0.35rem;
    }

    .card-description {
      max-height: none;
      margin: 0.25rem 0 0.6rem;
      font-size: 0.8rem;
    }

    .card-description p {
      line-height: 1.45;
    }

    .card-badges {
      opacity: 1;
    }

    .badge {
      font-size: 0.65rem;
      padding: 0.2rem 0.6rem;
    }
  }

  /* Größenabhängiges Overlay: kleine Kacheln zeigen weniger, statt zu
     scrollen. Details stehen ohnehin im Modal. */

  /* Flache Kacheln (2x1 im Bento, Mobile-Karten): kompakter,
     Beschreibung auf 2 Zeilen begrenzt */
  @container project-card (max-height: 300px) {
    .card-overlay {
      padding: 1rem 1.1rem;
    }

    .card-description p {
      -webkit-line-clamp: 2;
    }
  }

  /* Schmale Kacheln (1x1 / 1x2 im Bento): nur Titel + Tech-Zeile,
     kein Scrollbalken im Overlay */
  @container project-card (max-width: 270px) {
    .card-overlay {
      overflow-y: hidden;
      padding: 0.9rem 1rem;
    }

    .card-description,
    .card-badges {
      display: none;
    }
  }
</style>

