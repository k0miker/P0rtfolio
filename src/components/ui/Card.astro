---
import { Image } from "astro:assets";

const { project, image } = Astro.props;

// Verwende cardDescriptionEN mit Fallback-Optionen
const cardDescription =
  project.cardDescriptionEN ||
  project.cardDescriptionEn ||
  project.description?.en ||
  project.description ||
  "No description available";

// Stelle sicher, dass die Kategorie immer gesetzt ist
const category = project.category || "Other";
---

<div
  class:list={["card-wrapper", project.tile && `tile-${project.tile}`]}
  data-category={category}
  data-allowed-sizes={project.grid?.map((s: string) => s.replace(/\s/g, "")).join("|")}
>
  <div class="box card-3d offscreen" data-modal-target={`modal-${project.id}`}>
    <div class="card-content">
      <Image
        src={image}
        alt={project.title}
        width={600}
        height={400}
        format="webp"
        loading="lazy"
        class="card-image"
      />
      <div class="card-overlay">
        <h3 class="card-title">{project.title}</h3>
        <p class="card-tech">
          {project.technologies?.join(" • ") || "No technologies specified"}
        </p>
        <div class="card-description">
          <p>{cardDescription}</p>
        </div>
        <div class="card-badges">
          {
            project.badges &&
              project.badges.map((badge) => <span class="badge">{badge}</span>)
          }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .card-wrapper {
    position: relative;
    z-index: 5;
    perspective: 1000px;
    height: 100%;
    border-radius: 15px;
    box-shadow: var(--card-elev);
    /* Expliziter Basis-Filter, damit das Spotlight-Dimmen (.has-hover)
       in beide Richtungen weich animiert – nicht nur beim Verdunkeln. */
    filter: brightness(1) saturate(1);
    transition:
      box-shadow 0.4s ease,
      filter 0.3s ease;
  }

  .card-wrapper:hover {
    box-shadow: var(--card-elev-hover);
  }

  .box {
    position: relative;
    overflow: hidden;
    border-radius: 15px;
    cursor: pointer;
    height: 100%;
    transform-style: preserve-3d;
    transform: translateZ(0);
    transition:
      transform 0.5s ease-out,
      box-shadow 0.4s ease;
    background-color: var(--bg-card);
    /* box-shadow: var(--elev-3); */
  }

  /* @keyframes cardGlow {
    0% {
      box-shadow:
      0 0 2px 1px var(--bg-primary),
      0 0 1px 0px var(--accent);
    }
    100% {
      box-shadow:
      0 0 2px 1px var(--bg-primary),
      0 0 5px 0px var(--accent);
    }
  } */

  .card-content {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 15px;
    overflow: hidden;
  }

  /* Akzent-Rahmen über dem Bild – ein inset-Shadow direkt auf .card-content
     würde vom darüber liegenden .card-image verdeckt. */
  .card-content::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 15px;
    box-shadow: inset 0 0 0 1px
      color-mix(in srgb, var(--accent) 25%, transparent);
    pointer-events: none;
    z-index: 2;
    transition: box-shadow 0.4s ease;
  }

  .card-image {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    object-position: top;
    transition:
      transform 0.5s ease-out,
      filter 0.4s ease-out;
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.528),
      rgba(0, 0, 0, 0.306) 70%,
      transparent
    );
    color: white;
    transform: translateY(100%);
    transition: transform 0.4s ease-out;
    max-height: 90%;
    overflow-y: auto;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 0.5rem;
  }

  .card-tech {
    font-size: 0.875rem;
    opacity: 0.8;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-description {
    margin: 0.75rem 0;
    font-size: 0.875rem;
    opacity: 0.9;
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s ease;
  }

  .card-description p {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    transition: opacity 0.3s ease-out;
    opacity: 0;
  }

  .badge {
    padding: 0.25rem 0.75rem;
    background-color: var(--accent);
    color: white;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: bold;
  }

  /* Hover Effekte (Elevation liegt auf .card-wrapper) */
  .box:hover .card-content::after {
    box-shadow: inset 0 0 0 1px
      color-mix(in srgb, var(--accent) 60%, transparent);
  }

  .box:hover .card-image {
    transform: scale(1.05);
    filter: blur(5px);
  }

  .box:hover .card-overlay {
    transform: translateY(-5%);
  }

  .box:hover .card-description {
    max-height: 200px;
  }

  .box:hover .card-badges {
    opacity: 1;
  }

  /* Elegante schmale Scrollbar für card-overlay */
  .card-overlay {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 99, 71, 0.5) transparent;
  }

  .card-overlay::-webkit-scrollbar {
    width: 3px;
  }

  .card-overlay::-webkit-scrollbar-track {
    background: transparent;
  }

  .card-overlay::-webkit-scrollbar-thumb {
    background: rgba(255, 99, 71, 0.5);
    border-radius: 999px;
  }

  .card-overlay::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 99, 71, 0.8);
  }

  /* Touch-Screen Geräte */
  @media (hover: none) {
    .card-description {
      max-height: 80px;
    }

    .card-overlay {
      .card-title {
        font-size: 0.9rem;
      }
      font-size: 0.8rem;
      line-height: 1.4;
      transform: translateY(0%);
      .card-badges {
        opacity: 0.8;
      }
    }
  }
</style>

