---
import "../css/fontawesome/css/fontawesome.css";
import "../css/fontawesome/css/all.min.css";
import CV from "../assets/doc/ColinBlome-WebDev-CV.pdf";
import skillsBg from "../assets/images/skills.webp";

const skills = [
  { name: "HTML", level: 85 },
  { name: "CSS", level: 76 },
  { name: "React", level: 74 },
  { name: "JavaScript", level: 70 },
  { name: "TypeScript", level: 40 },
  { name: "Astro", level: 83 },
  { name: "React Native", level: 65 },
  { name: "Tailwind", level: 72 },
  { name: "Node.js", level: 65 },
  { name: "Express.js", level: 62 },
  { name: "MongoDB", level: 68 },
  { name: "Figma", level: 80 },
  { name: "GitHub", level: 75 },
  { name: "SCSS", level: 50 },
  { name: "NoSQL", level: 68 },
  { name: "SQL", level: 65 },
  { name: "Server Management", level: 55 },
  { name: "Windows", level: 80 },
  { name: "Linux", level: 75 },
];

const stack = [
  { icon: "fa-brands fa-html5", label: "HTML5" },
  { icon: "fa-brands fa-css3", label: "CSS3" },
  { icon: "fa-brands fa-react", label: "React" },
  { icon: "fa-brands fa-js", label: "JavaScript" },
  { icon: "fa-brands fa-sass", label: "Sass" },
  { icon: "fa-brands fa-linux", label: "Linux" },
  { icon: "fa-brands fa-windows", label: "Windows" },
  { icon: "fa-brands fa-github", label: "Github" },
  { icon: "fa-brands fa-node", label: "Node.js" },
  { icon: "fa-solid fa-database", label: "Database" },
  { icon: "fa-solid fa-server", label: "Server" },
  { icon: "fa-brands fa-figma", label: "Figma" },
  { icon: "fa-brands fa-android", label: "Android" },

];
---

<!-- Optimierter Hintergrund für mobile Geräte -->
<div
  class="flex flex-col box justify-center items-center min-h-[100vh]"
  id="skills"
>
  <div class="terminal-window skills-terminal offscreen">
    <div class="terminal-titlebar">
      <div class="terminal-dots" aria-hidden="true">
        <span class="dot-red"></span>
        <span class="dot-yellow"></span>
        <span class="dot-green"></span>
      </div>
      <span class="terminal-title">skills.sh — colin@webdev</span>
    </div>

    <div class="terminal-body">
      <p class="terminal-cmd">
        <span class="usr">colin@webdev</span><span class="punct">:</span><span
          class="pth">~</span
        ><span class="punct">$</span> ./skills --list
      </p>

      <div class="skill-list">
        {
          skills.map((s) => (
            <div class="skill">
              <span class="skill-name">{s.name}</span>
              <div
                class="skill-level"
                role="progressbar"
                aria-valuenow={s.level}
                aria-valuemin="0"
                aria-valuemax="100"
                aria-label={`${s.name}: ${s.level}%`}
              >
                <div style={`width: ${s.level}%`} class="skill-percent" />
              </div>
              <span class="skill-val">{s.level}%</span>
            </div>
          ))
        }
      </div>

      <p class="terminal-cmd terminal-cmd--stack">
        <span class="usr">colin@webdev</span><span class="punct">:</span><span
          class="pth">~</span
        ><span class="punct">$</span> ./skills --stack
      </p>

      <div class="flex wrapper stack-icons">
        {
          stack.map((item) => (
            <div class="icon-wrapper">
              <i class={`${item.icon} text-gray-600`} />
              <span class="icon-label">{item.label}</span>
            </div>
          ))
        }
      </div>

      <p class="terminal-cmd terminal-cmd--last">
        <span class="usr">colin@webdev</span><span class="punct">:</span><span
          class="pth">~</span
        ><span class="punct">$</span> <span class="term-cursor">_</span>
      </p>
    </div>
  </div>

  <a
    href={CV}
    target="_blank"
    class="mt-[8vh] p-3 cv rounded-lg font-bold offscreen animate-cv text-lg"
    >./download-cv.pdf</a
  >
</div>

<style define:vars={{ skillsBgUrl: `url(${skillsBg.src})` }}>
  .box {
    padding: 5vw;
    background-image: var(--skillsBgUrl);
    background-size: cover !important;
    background-attachment: fixed !important;
    background-position: center !important;
  }

  /* iOS Safari unterstützt background-attachment: fixed nicht korrekt */
  @media (hover: none) and (pointer: coarse) {
    .box {
      background-attachment: scroll !important;
    }
  }

  .skills-terminal {
    max-width: clamp(600px, 85vw, 1100px);
    width: 90%;
  }

  /* ===== skills --list ===== */
  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin: 0.4rem 0 0;
  }

  .skill {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    /* padding: 0.3rem 0.5rem; */
    border-radius: 6px;
    transition: background-color 0.25s ease;
  }
  .skill:hover {
    background: var(--term-hover-bg);
  }

  .skill-name {
    flex: 0 0 7.5rem;
    color: var(--term-text);
    font-family: var(--font-mono);
    font-size: var(--step--1);
    transition: color 0.25s ease;
  }
  .skill:hover .skill-name {
    color: var(--accent);
  }

  .skill-level {
    position: relative;
    flex: 1;
    min-width: 80px;
    height: 14px;
    background: var(--term-track-bg);
    border: 1px solid var(--term-input-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .skill-percent {
    position: absolute;
    inset: 0 auto 0 0;
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, #ff7a5c, var(--accent));
    opacity: 0;
    transition:
      opacity 0.5s ease,
      width 0.8s ease;
  }
  .animate .skill-percent {
    opacity: 1;
  }

  .skill-val {
    flex: 0 0 auto;
    min-width: 3.4ch;
    text-align: right;
    color: var(--term-path-color);
    font-family: var(--font-mono);
    font-size: 0.85em;
    transition: color 0.25s ease;
  }
  .skill:hover .skill-val {
    color: var(--accent);
  }

  /* Low-Performance-Modus: Balken sofort sichtbar, keine Animation */
  [data-performance="low"] .skill-percent {
    opacity: 1;
    animation: none !important;
    transition: none !important;
  }

  /* ===== skills --stack (Icon-Grid) ===== */
  .terminal-cmd--stack {
    margin-top: 1.6rem;
  }

  .wrapper {
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 0;
    margin-top: 0.6rem;
  }

  .icon-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .icon-wrapper i {
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-size: 32px;
    padding: 10px;
    color: var(--term-path-color);
    will-change: transform, color;
    backface-visibility: hidden;
  }
  .icon-label {
    opacity: 0;
    transform: translate(0, -5px) scale(0.7);
    transition: 0.5s;
    font-size: 10px;
    margin-top: 5px;
    color: var(--term-cmd-color);
    font-family: var(--font-mono);
  }
  .icon-wrapper:hover i {
    transform: scale(1.2) translate(0, -5px);
    color: var(--accent);
  }
  .icon-wrapper:hover .icon-label {
    color: var(--accent);
    opacity: 1;
    transform: translate(0, -5px) scale(1.2);
  }

  /* ===== Download CV ===== */
  .cv {
    box-shadow: var(--elev-2);
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    position: relative;
    border: 2px solid transparent;
    padding: 0.75rem 1.5rem;
    overflow: hidden;
    font-family: var(--font-mono);
  }
  .cv:hover {
    color: var(--accent);
    transform: scale(1.05);
    animation: border-glow 3s infinite;
  }
  .cv::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transition: left 0.7s;
  }
  .cv:hover::before {
    left: 100%;
  }

  @keyframes pulse-shadow {
    0% {
      box-shadow: 0 0 5px transparent;
    }
    50% {
      box-shadow:
        0 0 35px var(--accent),
        inset 0 0 15px 0px var(--bg-secondary);
    }
    100% {
      box-shadow: 0 0 5px transparent;
    }
  }
  @keyframes border-glow {
    0% {
      border-color: transparent;
    }
    50% {
      border-color: var(--accent);
    }
    100% {
      border-color: transparent;
    }
  }
  .animate-cv {
    animation: pulse-shadow 3s infinite;
  }

  @media (max-width: 768px) {
    .skills-terminal {
      width: 100%;
    }
    .skill-name {
      flex-basis: 5.5rem;
      font-size: 0.8rem;
    }
    .icon-wrapper i {
      font-size: 26px;
    }
    @supports (content-visibility: auto) {
      .icon-wrapper {
        content-visibility: auto;
        contain-intrinsic-size: 0 40px;
      }
    }
  }
</style>

<script>
  import { performanceMonitor } from '../utils/performanceMonitor.js';

  document.addEventListener("DOMContentLoaded", () => {
    const skillsSection = document.getElementById("skills");
    const skillPercents = document.querySelectorAll(".skill-percent");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Im Low-Performance-Modus keine "animate"-Klasse hinzufügen
          const isLowPerformance = document.documentElement.getAttribute('data-performance') === 'low';

          if (!isLowPerformance) {
            entry.target.classList.add("animate");

            skillPercents.forEach((skillBar, index) => {
              (skillBar as HTMLElement).style.transitionDelay = `${index * 0.1}s`;
            });
          } else {
            // Im Low-Performance-Modus nur Opacity setzen, keine Animationen
            skillPercents.forEach((skillBar) => {
              (skillBar as HTMLElement).style.opacity = '1';
            });
          }
        } else {
          entry.target.classList.remove("animate");
        }
      });
    }, { threshold: 0.1 });

    if (skillsSection) {
      observer.observe(skillsSection);

      // Original-Hintergrund speichern
      if (!skillsSection.hasAttribute('data-original-background')) {
        const computedStyle = window.getComputedStyle(skillsSection);
        const backgroundImage = computedStyle.backgroundImage;
        if (backgroundImage && backgroundImage !== 'none') {
          skillsSection.setAttribute('data-original-background', backgroundImage);
        }
      }

      // Performance-Modus prüfen
      const currentMode = document.documentElement.getAttribute('data-performance') ||
                          localStorage.getItem('performance-mode') || 'high';

      // Im Low-Performance-Modus Animationen deaktivieren, aber Hintergrund behalten
      if (currentMode === 'low') {
        skillsSection.style.backgroundAttachment = 'scroll';
        skillsSection.classList.add('static-background');

        // Animation entfernen, aber Hintergrund behalten
        const animations = skillsSection.getAnimations();
        animations.forEach(animation => {
          animation.cancel();
        });
      }

      // Auf Performance-Modus-Änderungen reagieren
      if (performanceMonitor) {
        // Initialen Zustand basierend auf dem aktuellen Performance-Modus setzen
        if (performanceMonitor.lowPerformanceMode) {
          // Animation deaktivieren, Hintergrund behalten
          skillsSection.style.backgroundAttachment = 'scroll';
          skillsSection.classList.add('static-background');
        }

        // Event-Listener für Performance-Mode-Änderungen
        document.addEventListener('performanceModeChange', (event) => {
          const mode = (event as CustomEvent).detail.mode;
          if (mode === 'low') {
            // Animation deaktivieren, Hintergrund behalten
            skillsSection.style.backgroundAttachment = 'scroll';
            skillsSection.classList.add('static-background');
            skillsSection.classList.remove('animate'); // Animate-Klasse entfernen
          } else {
            // Normale Darstellung wiederherstellen
            skillsSection.style.backgroundAttachment = '';
            skillsSection.classList.remove('static-background');
            // animate-Klasse wieder hinzufügen wenn sichtbar
            if (skillsSection.getBoundingClientRect().top < window.innerHeight) {
              skillsSection.classList.add('animate');
            }
          }
        });

        // Initialen Performance-Modus beachten
        if (performanceMonitor && performanceMonitor.lowPerformanceMode) {
          skillPercents.forEach((skillBar) => {
            (skillBar as HTMLElement).style.opacity = '1';
          });
        }
      }
    }
  });
</script>
