---
import myself from "../assets/images/Cartoonify.svg";
import myself3 from "../assets/images/myself.jpg";
// import { age } from "../scripts/age.js";

let date_now = new Date();
let date_birthday = new Date("1986-04-30");
let age = date_now.getFullYear() - date_birthday.getFullYear();

// Überprüfe, ob der Geburtstag in diesem Jahr bereits war
const hasHadBirthdayThisYear =
  date_now.getMonth() > date_birthday.getMonth() ||
  (date_now.getMonth() === date_birthday.getMonth() &&
    date_now.getDate() >= date_birthday.getDate());

// Wenn der Geburtstag noch nicht war, ziehe 1 Jahr ab
if (!hasHadBirthdayThisYear) {
  age--;
}
---

<div class="wrap sm:flex-col rounded-lg offscreen relative">
  <h3
    class="py-5 font-[mono] text-4xl text-center offscreen hover:tracking-[.51vw] hover:text-[tomato] text-[var(--text-primary)]"
  >
    About<span class="animate-ping">_</span>
  </h3>
  <div class="flex flex-col items-center offscreen">
    <div class="foto-swich">
      <img
        src={myself.src}
        class="sm:w-[100%] opacity-100"
        alt="foto of colin"
      />
      <img src={myself3.src} class="sm:w-[100%]" alt="foto of colin" />
    </div>

    <div class="content-section">
      <div class="terminal-window">
        <div class="terminal-titlebar">
          <div class="terminal-dots" aria-hidden="true">
            <span class="dot-red"></span>
            <span class="dot-yellow"></span>
            <span class="dot-green"></span>
          </div>
          <span class="terminal-title">about.md — colin@webdev</span>
          <div class="lang-buttons">
            <button type="button" class="lang-btn active" data-lang="en"
              >EN</button
            >
            <button type="button" class="lang-btn" data-lang="de">DE</button>
          </div>
        </div>

        <div class="terminal-body">
          <p class="terminal-cmd">
            <span class="usr">colin@webdev</span><span class="punct">:</span><span
              class="pth">~</span
            ><span class="punct">$</span> cat about.md
          </p>

          <div class="language-content active" id="content-en">
            <p>
              Hello! <br />
              I'm Colin, a {age}-year-old passionate web developer. Since my
              youth, I've been a true PC nerd with a strong affinity for
              technology. Besides my work as a web developer, I'm also an avid
              gamer who loves spending my free time on challenging games.
              Additionally, I have a special passion for bonsai art, which helps
              me find calm and balance in my daily life. With my diverse
              experience and wide-ranging interests, I bring creative and
              functional solutions to my projects. Whether it's developing a
              user-friendly website or tackling complex technical challenges –
              I'm always motivated to achieve the best results and help my
              clients reach their goals.
            </p>
          </div>

          <div class="language-content" id="content-de">
            <p>
              Hallo! <br />
              Ich bin Colin, ein {age}-jähriger leidenschaftlicher
              Webentwickler. Seit meiner Jugend bin ich ein echter PC-Nerd mit
              einer starken Affinität für Technologie. Neben meiner Arbeit als
              Webentwickler bin ich auch ein begeisterter Gamer und verbringe
              gerne meine Freizeit mit anspruchsvollen Spielen. Zusätzlich habe
              ich eine besondere Leidenschaft für die Bonsai-Kunst, die mir
              hilft, Ruhe und Ausgleich in meinen Alltag zu bringen. Mit meiner
              vielfältigen Erfahrung und meinen breitgefächerten Interessen
              bringe ich kreative und funktionale Lösungen in meine Projekte
              ein. Egal ob es darum geht, eine benutzerfreundliche Webseite zu
              entwickeln oder komplexe technische Herausforderungen zu lösen –
              ich bin immer motiviert, die besten Ergebnisse zu erzielen und
              meinen Kunden zu helfen, ihre Ziele zu erreichen.
            </p>
          </div>

          <p class="terminal-cmd terminal-cmd--last">
            <span class="usr">colin@webdev</span><span class="punct">:</span><span
              class="pth">~</span
            ><span class="punct">$</span> <span class="term-cursor">_</span>
          </p>
        </div>
      </div>

      <div class="terminal-window">
        <div class="terminal-titlebar">
          <div class="terminal-dots" aria-hidden="true">
            <span class="dot-red"></span>
            <span class="dot-yellow"></span>
            <span class="dot-green"></span>
          </div>
          <span class="terminal-title">whoami — colin@webdev</span>
        </div>

        <div class="terminal-body">
          <p class="terminal-cmd">
            <span class="usr">colin@webdev</span><span class="punct">:</span><span
              class="pth">~</span
            ><span class="punct">$</span> whoami --tags
          </p>

          <ul class="term-tags">
            <li>
              <span class="term-arrow">&gt;</span>
              <i class="fa-solid fa-keyboard"></i>
              <span>Web Developer</span>
            </li>
            <li>
              <span class="term-arrow">&gt;</span>
              <i class="fa-solid fa-user"></i>
              <span>UI/UX Enthusiast</span>
            </li>
            <li>
              <span class="term-arrow">&gt;</span>
              <i class="fa-solid fa-leaf"></i>
              <span>Bonsai Enthusiast</span>
            </li>
          </ul>

          <p class="terminal-cmd terminal-cmd--last">
            <span class="usr">colin@webdev</span><span class="punct">:</span><span
              class="pth">~</span
            ><span class="punct">$</span> <span class="term-cursor">_</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const langBtns = document.querySelectorAll(".lang-btn");
    const langContents = document.querySelectorAll(".language-content");

    langBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const lang = btn.getAttribute("data-lang");

        // Update active button
        langBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        // Update active content
        langContents.forEach((content) => {
          content.classList.remove("active");
          if (content.id === `content-${lang}`) {
            content.classList.add("active");
          }
        });
      });
    });
  });
</script>

<style>
  .wrap {
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-top: 40px;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    height: fit-content;
  }

  img {
    width: 30%;
    max-width: 250px;
    opacity: 0.8;
    outline: 1px solid var(--border);
    object-fit: cover;
    border-radius: 15px;
    aspect-ratio: 1;
    transition: outline-color 0.3s ease;
  }

  h3 {
    font-family: mono;
    text-shadow: 2px 2px 3px rgba(255, 255, 255, 0);
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--text-titel);
  }

  p {
    font-family: "Inter", sans-serif;
    color: var(--text-primary);
    transition: 0.5s;
    line-height: 1.6;
    text-align: left;
  }

  .content-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 0 5vw;
    margin-top: 2rem;
  }

  .content-box {
    width: 90%;
    max-width: 1200px;
    background-color: var(--form-bg);
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
    position: relative;
    margin-bottom: 2rem;
  }

  .language-switcher {
    display: flex;
    justify-content: flex-end;
    padding: 0.5rem;
    background-color: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
  }

  .lang-btn {
    background: none;
    border: 1px solid transparent;
    padding: 0.25rem 0.75rem;
    margin-left: 0.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-family: mono;
    font-size: 0.8rem;
    color: var(--text-titel);
    transition: all 0.3s ease;
  }

  .lang-btn:hover {
    color: tomato;
  }

  .lang-btn.active {
    border-color: var(--border);
    color: tomato;
    background-color: var(--bg-card);
  }

  .language-content {
    display: none;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.5s ease;
  }

  .language-content.active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== Terminal-Fenster (Bio) ===== */
  /* Basis-Chrome (.terminal-window/-titlebar/-dots/-title/-body/-cmd/-cursor)
     liegt jetzt global in css/terminal.css. Hier nur About-Spezifisches. */

  /* EN/DE als Terminal-Tabs auf der dunklen Leiste */
  .terminal-titlebar .lang-buttons {
    display: flex;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .terminal-titlebar .lang-btn {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(235, 235, 235, 0.65);
    padding: 0.15rem 0.6rem;
    margin: 0;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .terminal-titlebar .lang-btn:hover {
    color: var(--accent);
    border-color: rgba(255, 99, 71, 0.5);
  }
  .terminal-titlebar .lang-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* Bio-Output: lesbar, aber im Terminal-Kontext */
  .terminal-body .language-content p {
    font-family: var(--font-body);
    color: #e6e6e6;
    line-height: 1.7;
    /* max-width: 70ch; */
    text-align: left;
    padding: 0;
  }

  /* whoami --tags Liste */
  .term-tags {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .term-tags li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: #e6e6e6;
    width: fit-content;
    transition:
      color 0.25s ease,
      transform 0.25s ease;
  }
  .term-tags li:hover {
    color: var(--accent);
    transform: translateX(5px);
  }
  .term-tags .term-arrow {
    color: var(--accent);
  }
  .term-tags i {
    width: 1.4em;
    text-align: center;
    color: #9a9a9a;
    transition: color 0.25s ease;
  }
  .term-tags li:hover i {
    color: var(--accent);
  }

  .content-header {
    background-color: var(--bg-secondary);
    padding: 1rem;
    text-align: center;
    font-size: 1.5rem;
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
  }
  .content-header2 {
    background-color: var(--bg-secondary);
    padding: .5rem;
    text-align: center;
    font-size: 1.5rem;
    transition: all 0.3s ease;
    width: 70%;
  }
  .content-header:hover,
  .content-header2:hover {
    letter-spacing: 0.51vw;
    color: var(--accent);
  }

  .skills-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
    padding: 1rem 1rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 0 30%;
    padding: 1rem;
    transition: all 0.3s ease;
    font-family: mono;
  }

  .skill-item i {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    padding: 1rem;
  }

  .skill-item:hover {
    color: tomato;
    transform: scale(1.1);
  }

  .foto-swich {
    display: flex;
    justify-content: center;
    width: 200px;
    border-radius: 0px;
    margin-bottom: 2rem;
  }

  .foto-swich img {
    width: 200px;
    transition: 0.5s;
  }

  .foto-swich:hover img:nth-of-type(2) {
    opacity: 1;
  }

  .foto-swich:hover img:nth-of-type(1) {
    opacity: 0;
  }

  .foto-swich img:nth-of-type(2) {
    transform: translateX(-50%);
    opacity: 0;
  }

  .foto-swich img:nth-of-type(1) {
    transform: translateX(50%);
  }

  @media (min-width: 1280px) {
    .wrap {
      min-height: unset;
      padding-bottom: 60px;
    }
    .content-box {
      max-width: 1600px;
      width: 90%;
    }
  }

  @media (max-width: 768px) {
    .skill-item i {
      font-size: 2rem;
      padding: 0.5rem;
    }

    .content-box {
      width: 95%;
    }

    p {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 480px) {
    .skills-container {
      flex-direction: column;
    }

    .skill-item {
      margin-bottom: 1rem;
    }

    .content-header {
      font-size: 1.25rem;
    }

    .lang-btn {
      padding: 0.15rem 0.5rem;
    }
  }

  @keyframes ping {
    75%,
    100% {
      opacity: 0;
    }
  }

  .animate-ping {
    animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>
