---
import Button from "./Button.astro";
import contactBg from "../assets/images/contact.webp";

---

<section
  class="flex flex-col items-center content-center min-h-[70vh] p-2"
  id="contact-section"
  style={`background-image: url(${contactBg.src})`}
>
  <div class="terminal-window contact-terminal offscreen">
    <div class="terminal-titlebar">
      <div class="terminal-dots" aria-hidden="true">
        <span class="dot-red"></span>
        <span class="dot-yellow"></span>
        <span class="dot-green"></span>
      </div>
      <span class="terminal-title">contact.sh — colin@webdev</span>
    </div>

    <div class="terminal-body">
      <p class="terminal-cmd">
        <span class="usr">colin@webdev</span><span class="punct">:</span><span
          class="pth">~</span
        ><span class="punct">$</span> ./contact --message
      </p>

      <form
        name="contact"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
        method="POST"
      >
        <input type="hidden" name="bot-field" />

        <div class="input-group">
          <label class="user-label" for="name">--name</label>
          <input required type="text" name="name" class="input" id="name" />
        </div>
        <div class="input-group">
          <label class="user-label" for="mail">--email</label>
          <input required type="email" name="email" class="input" id="mail" />
        </div>
        <div class="input-group">
          <label class="user-label" for="message">--message</label>
          <textarea
            required
            name="text"
            rows="5"
            autocomplete="off"
            class="textarea input"
            id="message"></textarea>
        </div>

        <div class="privacy-line">
          <span class="privacy-prompt">[?]</span>
          <div class="toggle-switch">
            <input type="checkbox" required id="toggle" class="toggle-input checkbox" aria-describedby="privacy-error" />
            <label for="toggle" class="toggle-label"></label>
          </div>
          <span class="privacy-text">I accept the <a
            href="/datenschutz"
            target="_blank"
            class="toggle-switch-label">privacy policy</a></span>
          <span class="privacy-yn">[y/N]</span>
          <p id="privacy-error" class="privacy-error" role="alert" aria-live="polite"></p>
        </div>

        <Button class="button" disabled />

        <div class="direct-contact">
          <p class="list-cmd"><span class="usr">colin@webdev</span><span class="punct">:</span><span class="pth">~</span><span class="punct">$</span><span class="cmdtext">./contact --list </span><span class="term-cursor"> _</span></p>
          <div class="flag-output">
            <div class="flag-row">
              <span class="flag-name">--email</span>
              <span class="flag-value email-text">info@colinblome.dev</span>
              <button class="copy-btn" data-copy="info@colinblome.dev">
                <i class="fas fa-copy"></i>
              </button>
            </div>
            <div class="flag-row">
              <span class="flag-name">--phone</span>
              <span class="flag-value phone-text" data-real="0173-609-8320">···········</span>
              <button class="reveal-btn" aria-label="Telefonnummer anzeigen">[reveal]</button>
              <button class="copy-btn" data-copy="017360983320">
                <i class="fas fa-copy"></i>
              </button>
            </div>
          </div>
        </div>
      </form>

      <p class="terminal-cmd terminal-cmd--last">
        <span class="usr">colin@webdev</span><span class="punct">:</span><span
          class="pth">~</span
        ><span class="punct">$</span> <span class="term-cursor">_</span>
      </p>
    </div>
  </div>
</section>

<style>
  section {
    align-items: center;
    justify-content: center;
    min-height: 95vh;
    padding: 5vw;
    background-size: cover !important;
    box-shadow: inset 0px -2vh 10vw 10px var(--shadow-strong);
    background-attachment: fixed !important;
    background-position: center !important;
  }

  @media (hover: none) and (pointer: coarse) {
    section { background-attachment: scroll !important; }
  }

  @media (max-width: 768px) {
    section { padding: 2rem 1rem; }
  }

  section.static-background {
    background-attachment: scroll;
  }

  .contact-terminal {
    max-width: clamp(600px, 75vw, 1100px);
    box-shadow: var(--elev-3);
  }

  .contact-terminal form {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    color: var(--term-cmd-color);
    margin-top: 0.4rem;
    gap: 0;
  }

  /* ── Input groups ── */
  .input-group {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 6px 12px 10px;
    width: 100%;
    max-width: clamp(450px, 60%, 700px);
  }

  /* > prefix aligned with label */
  .input-group::before {
    content: ">";
    position: absolute;
    left: 14px;
    top: 8px;
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: bold;
    font-size: 0.88rem;
    pointer-events: none;
  }

  .user-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--term-punct-color);
    padding-left: 22px;
    pointer-events: none;
    transition: color 0.2s;
  }

  .input-group:focus-within .user-label {
    color: var(--accent);
  }

  .input {
    border: solid 1px var(--term-input-border);
    border-radius: 4px;
    background: var(--term-input-bg);
    padding: 0.4rem 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--term-text);
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
    width: 100%;
  }

  .textarea {
    resize: vertical;
    border-radius: 4px;
  }

  .input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 1px rgba(239, 91, 45, 0.2);
  }

  /* ── Privacy line ── */
  .privacy-line {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--term-cmd-color);
    max-width: clamp(450px, 60%, 700px);
    width: 100%;
    padding: 8px 12px 4px;
  }

  .privacy-prompt {
    color: var(--accent);
    font-weight: bold;
  }

  .privacy-yn {
    color: var(--term-punct-color);
    transition: color 0.2s;
  }

  .privacy-yn.accepted {
    color: #4caf50;
  }

  .privacy-text a.toggle-switch-label {
    color: var(--accent);
    text-decoration: underline;
  }

  .privacy-error {
    display: none;
    width: 100%;
    color: #e53e3e;
    font-size: 0.78rem;
    margin-top: 0.15rem;
    font-family: var(--font-mono);
  }

  .privacy-error.visible {
    display: block;
  }

  /* ── Toggle switch ── */
  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 25px;
    flex-shrink: 0;
  }

  .toggle-switch .toggle-input {
    display: none;
  }

  .toggle-switch .toggle-label {
    position: absolute;
    top: 0;
    left: 0;
    width: 40px;
    height: 24px;
    background-color: var(--toggle-off-bg);
    border-radius: 14px;
    cursor: pointer;
    transition: background-color 0.3s;
  }

  .toggle-switch .toggle-label::before {
    content: "";
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    top: 2px;
    left: 2px;
    background-color: #fff;
    box-shadow: 0px 2px 5px 0px rgba(0, 0, 0, 0.3);
    transition: transform 0.3s;
  }

  .toggle-switch .toggle-input:checked + .toggle-label {
    background-color: var(--toggle-on-bg);
  }

  .toggle-switch .toggle-input:checked + .toggle-label::before {
    transform: translateX(16px);
  }

  /* ── Direct contact — flag-output style ── */
  .direct-contact {
    width: 100%;
    max-width: clamp(450px, 60%, 700px);
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0 12px;
  }

  .list-cmd {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    margin-bottom: 0.15rem;
      .punct,
      .pth,
      .cmdtext {
        opacity: 0.65;
      }
  }


  .flag-output {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .flag-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
  }

  .flag-name {
    color: var(--term-path-color);
    min-width: 72px;
  }

  .flag-value {
    color: var(--accent);
    transition: color 0.2s;
  }

  .email-text {
    cursor: pointer;
  }

  .email-text:hover {
    color: color-mix(in srgb, var(--accent) 70%, white);
  }

  .phone-text {
    letter-spacing: 0.05em;
  }

  .reveal-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--term-punct-color);
    padding: 0;
    transition: color 0.2s;
  }

  .reveal-btn:hover {
    color: var(--accent);
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--term-punct-color);
    font-size: 0.78rem;
    padding: 0.15rem;
    border-radius: 3px;
    transition: color 0.2s;
  }

  .copy-btn:hover {
    color: var(--accent);
  }

  .copy-btn.copied {
    color: #4caf50;
  }

  .highlight {
    animation: highlight 0.5s;
  }

  @keyframes highlight {
    0% { scale: 1; }
    50% { scale: 1.05; }
    100% { background-color: #33333391; }
  }

  @media (max-width: 480px) {
    section { padding: 1.5rem 0.75rem; }
  }
</style>

<script>
  const form = document.querySelector("form");
  const input = document.querySelector(".checkbox") as HTMLInputElement;
  const toggle = document.querySelector(".toggle-switch");
  const toggleLabel = document.querySelector(".toggle-label");
  const privacyError = document.getElementById("privacy-error");
  const privacyYN = document.querySelector(".privacy-yn");

  form.addEventListener("submit", (event) => {
    if (!input.checked) {
      event.preventDefault();
      toggle.classList.add("highlight");
      toggleLabel.classList.add("highlight");
      if (privacyError) {
        privacyError.textContent = "Bitte stimme der Datenschutzerklärung zu.";
        privacyError.classList.add("visible");
      }
      setTimeout(() => {
        toggle.classList.remove("highlight");
        toggleLabel.classList.remove("highlight");
      }, 500);
    }
  });

  input?.addEventListener("change", () => {
    if (input.checked) {
      if (privacyError) {
        privacyError.classList.remove("visible");
        privacyError.textContent = "";
      }
      if (privacyYN) {
        privacyYN.textContent = "[Y/n]";
        privacyYN.classList.add("accepted");
      }
    } else {
      if (privacyYN) {
        privacyYN.textContent = "[y/N]";
        privacyYN.classList.remove("accepted");
      }
    }
  });

  document.addEventListener("DOMContentLoaded", () => {
    const copyButtons = document.querySelectorAll(".copy-btn");
    copyButtons.forEach((button) => {
      button.addEventListener("click", function (e) {
        e.stopPropagation();
        const textToCopy = this.getAttribute("data-copy");
        navigator.clipboard.writeText(textToCopy).then(() => {
          this.classList.add("copied");
          const originalIcon = this.innerHTML;
          this.innerHTML = '<i class="fas fa-check"></i>';
          setTimeout(() => {
            this.classList.remove("copied");
            this.innerHTML = originalIcon;
          }, 2000);
        });
      });
    });

    const revealBtn = document.querySelector(".reveal-btn");
    const phoneText = document.querySelector(".phone-text") as HTMLElement;
    if (revealBtn && phoneText) {
      revealBtn.addEventListener("click", () => {
        const isHidden = phoneText.textContent === "···········";
        phoneText.textContent = isHidden ? phoneText.dataset.real : "···········";
        revealBtn.textContent = isHidden ? "[hide]" : "[reveal]";
      });
    }

    const emailText = document.querySelector(".email-text");
    if (emailText) {
      emailText.addEventListener("click", (e) => {
        e.stopPropagation();
        window.location.href = "mailto:info@colinblome.dev";
      });
    }

    if (phoneText) {
      phoneText.addEventListener("click", (e) => {
        e.stopPropagation();
        if (phoneText.dataset.real && phoneText.textContent !== "···········") {
          window.location.href = "tel:+4917360983320";
        }
      });
    }
  });
</script>
